{
  "functions": {
    "source": "functions",
    "runtime": "nodejs22",
    "artifactRegistry": {
      "cleanupPolicyDays": 30,
      "location": "europe-west1"
    },
    "predeploy": [
      "npm --prefix \"$RESOURCE_DIR\" run build"
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  }
}
