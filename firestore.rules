rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isCoach() {
      return request.auth != null
        && request.auth.token.email == 'info.teamhaim@gmail.com';
    }
    function isSelf(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      // Self-writes are allowed, but a non-coach can never set their own
      // (or anyone else's) role to 'coach' this way — only the real
      // coach account (isCoach(), checked against the verified Google
      // auth token email) can ever write role: 'coach'. Without this,
      // the client-side check in auth-context.tsx is cosmetic only:
      // anyone signed in could call Firestore directly and grant
      // themselves the coach role.
      allow write: if isCoach()
        || (isSelf(userId) && request.resource.data.role != 'coach');
      match /journey/{journeyId} {
        allow read, write: if isSelf(userId) || isCoach();
      }
    }

    match /workouts/{workoutId} {
      allow read: if request.auth != null;
      allow write: if isCoach();
    }

    match /assignedWorkouts/{docId} {
      allow read: if request.auth != null;
      allow create, delete: if isCoach();
      // Athletes may complete/skip their workout or move it to another day
      // (movedByAthlete/movedFromDate flag the move for the coach).
      allow update: if isCoach()
        || (request.auth != null
            && resource.data.athleteId == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['status', 'completedAt', 'athleteNotes', 'updatedAt',
                         'scheduledDate', 'movedByAthlete', 'movedFromDate']));
    }

    match /logs/{logId} {
      allow read: if request.auth != null
        && (isCoach() || resource.data.athleteId == request.auth.uid);
      allow create: if request.auth != null
        && (isCoach() || request.resource.data.athleteId == request.auth.uid);
      allow update, delete: if isCoach()
        || (request.auth != null && resource.data.athleteId == request.auth.uid);
    }

    match /messages/{messageId} {
      allow read, write: if request.auth != null;
    }

    match /goals/{goalId} {
      allow read, write: if request.auth != null;
    }

    match /settings/googleSheets {
      allow read: if request.auth != null;
      allow write: if isCoach();
    }

    match /strava_connections/{docId} {
      allow read, write: if request.auth != null;
    }

    match /weeklyNotes/{docId} {
      allow read: if request.auth != null
        && (isCoach() || resource.data.athleteId == request.auth.uid);
      allow create, delete: if isCoach();
      allow update: if isCoach()
        || (request.auth != null
            && resource.data.athleteId == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['readByAthlete']));
    }

    match /lactateTests/{docId} {
      allow read: if request.auth != null
        && (isCoach() || resource.data.athleteId == request.auth.uid);
      // Athletes can log/edit their own tests (lab is now self-serve, not
      // just coach-entered); coach can do the same for any athlete.
      allow create: if isCoach()
        || (request.auth != null && request.resource.data.athleteId == request.auth.uid);
      allow update, delete: if isCoach()
        || (request.auth != null && resource.data.athleteId == request.auth.uid);
    }

    match /coachMessages/{docId} {
      allow read: if request.auth != null
        && (isCoach() || resource.data.athleteId == request.auth.uid);
      allow create, delete: if isCoach();
      allow update: if isCoach()
        || (request.auth != null
            && resource.data.athleteId == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['read', 'readAt']));
    }

    // Push notification tokens — doc id is the user's own uid. Every
    // athlete and the coach write their own token here when enabling
    // notifications; there was no rule for this collection at all before,
    // so every registration was silently denied (default-deny) and no one
    // could receive pushes.
    match /fcmTokens/{userId} {
      allow read, write: if isSelf(userId) || isCoach();
    }

    // Scheduled reminder notifications (morning/evening cron jobs etc.)
    match /scheduledNotifications/{docId} {
      allow read: if request.auth != null
        && (isCoach() || resource.data.userId == request.auth.uid);
      allow create: if request.auth != null
        && (isCoach() || request.resource.data.userId == request.auth.uid);
      allow update, delete: if isCoach();
    }
  }
}
